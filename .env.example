# Copy this file to .env and fill in your real values.
# NEVER commit .env — it contains live secrets.
#
# Obtain these values:
#   BOT_TOKEN    → https://t.me/BotFather
#   API_ID/HASH  → https://my.telegram.org/apps
#   DB_PASSWORD  → set to any strong random password
#   SESSION_NAME → arbitrary name for the Telethon session file (no spaces)

# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Telegram MTProto (Telethon — used for channel parsing) ───────────────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_NAME=bot_parser_session

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PASSWORD is also read by docker-compose.yml for the Postgres container.
# Use the same value in all three variables below.
DB_PASSWORD=change_me_strong_password
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:change_me_strong_password@db:5432/parsing_bot
DATABASE_URL_SYNC=postgresql://postgres:change_me_strong_password@db:5432/parsing_bot

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Credit system ─────────────────────────────────────────────────────────────
INITIAL_CREDITS=5
PAID_PARSE_COUNT=4
STARS_PRICE=100

# ── Stale job thresholds (minutes) ───────────────────────────────────────────
STALE_PROCESSING_MINUTES=10
STALE_PENDING_MINUTES=5

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=False
